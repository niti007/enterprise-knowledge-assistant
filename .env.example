# ============================================================
# Enterprise Knowledge Assistant — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Langfuse (observability) ---
# Sign up at https://cloud.langfuse.com → New Project → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Neo4j (graph DB) ---
# Default values match docker-compose.yml
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Redis (semantic cache) ---
# Default values match docker-compose.yml (no auth in dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Tavily (web search tool, optional) ---
# Sign up at https://tavily.com → dashboard → copy key
# If empty, web_search tool is disabled
TAVILY_API_KEY=

# --- Cohere (optional reranker) ---
# If empty, local cross-encoder (sentence-transformers) is used instead
COHERE_API_KEY=

# --- App settings ---
APP_ENV=development
LOG_LEVEL=INFO
# LLM model defaults
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_ADVANCED_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=enterprise_kb
# Chunk settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Retrieval
RETRIEVAL_TOP_K=5
